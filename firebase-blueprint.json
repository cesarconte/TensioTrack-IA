{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other", "prefer-not-to-say"] },
        "age": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["admin", "patient", "doctor"] }
      },
      "required": ["uid", "email"]
    },
    "Authorization": {
      "title": "Doctor Authorization",
      "description": "Patient authorization granting access to a doctor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "revoked"] }
      },
      "required": ["id", "patientId", "doctorId", "createdAt"]
    },
    "Reading": {
      "title": "Blood Pressure Reading",
      "description": "A single blood pressure measurement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "systolic": { "type": "number" },
        "diastolic": { "type": "number" },
        "heartRate": { "type": "number" },
        "order": { "type": "integer" },
        "slot": { "type": "string", "enum": ["morning", "evening"] },
        "recordedAt": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "userUid": { "type": "string" }
      },
      "required": ["systolic", "diastolic", "order", "slot", "recordedAt", "date", "userUid"]
    },
    "AiAnalysis": {
      "title": "AI Analysis",
      "description": "Cached AI analysis for a specific period and type",
      "type": "object",
      "properties": {
        "analysis": { "type": "string" },
        "type": { "type": "string", "enum": ["bp", "pulse"] },
        "period": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userUid": { "type": "string" }
      },
      "required": ["analysis", "type", "period", "createdAt", "userUid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/authorizations/{authId}": {
      "schema": "Authorization",
      "description": "Patient to doctor authorizations"
    },
    "/users/{userId}/readings/{readingId}": {
      "schema": "Reading",
      "description": "User blood pressure readings"
    },
    "/users/{userId}/ai_analysis/{analysisId}": {
      "schema": "AiAnalysis",
      "description": "User cached AI analysis"
    },
    "/users/{userId}/ai_reports/{reportId}": {
      "schema": { "$ref": "#/entities/AiReport" },
      "description": "User generated AI reports"
    }
  }
}
