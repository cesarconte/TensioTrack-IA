rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Connectivity Test (Startup check)
    // ===============================================================
    match /test/connection {
      allow read: if true;
    }

    // ===============================================================
    // Helper Functions (The Primitives)
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    
    // PERMISSION MANDATE: Allow signed in users; verification check is softened for dev/social logins
    function isVerified() { 
      return isSignedIn(); // Relaxed for better UX
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Guard against ID poisoning/pollution
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    // Tiered Identity Logic: RBAC using Custom Claims (Optimized Cost & Performance)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "yugurta@gmail.com" ||
        request.auth.token.admin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isDoctor() {
      return isSignedIn() && (
        request.auth.token.doctor == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor'
      );
    }

    function isAuthorizedDoctor(patientId) {
      return isDoctor() && 
        exists(/databases/$(database)/documents/authorizations/$(request.auth.uid + '_' + patientId));
    }

    // ===============================================================
    // Entity Validation Blueprints (Anti-Update-Gap)
    // ===============================================================

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256 &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (!('uid' in data) || data.uid is string) &&
             (!('displayName' in data) || data.displayName == null || (data.displayName is string && data.displayName.size() <= 256)) &&
             (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 200000)) &&
             (!('sex' in data) || data.sex in ['male', 'female', 'other']) &&
             (!('age' in data) || data.age == null || (data.age is number && data.age >= 0 && data.age <= 120)) &&
             (!('height' in data) || data.height == null || (data.height is number && data.height >= 0 && data.height <= 300)) &&
             (!('weight' in data) || data.weight == null || (data.weight is number && data.weight >= 0 && data.weight <= 500)) &&
             (!('isSmoker' in data) || data.isSmoker is bool) &&
             (!('hasDiabetes' in data) || data.hasDiabetes is bool) &&
             (!('isHypertensiveMedicated' in data) || data.isHypertensiveMedicated is bool) &&
             (!('activityLevel' in data) || data.activityLevel in ['sedentary', 'moderate', 'active']) &&
             (!('alcoholConsumption' in data) || data.alcoholConsumption in ['none', 'occasional', 'frequent']) &&
             (!('saltIntake' in data) || data.saltIntake in ['low', 'normal', 'high']) &&
             (!('stressLevel' in data) || data.stressLevel in ['low', 'moderate', 'high']) &&
             (!('sleepQuality' in data) || data.sleepQuality in ['good', 'average', 'poor']) &&
             (!('familyHistory' in data) || data.familyHistory is bool) &&
             (!('caffeineIntake' in data) || data.caffeineIntake in ['none', 'low', 'moderate', 'high']) &&
             (!('hasHighCholesterol' in data) || data.hasHighCholesterol is bool) &&
             (!('hasKidneyDisease' in data) || data.hasKidneyDisease is bool) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('aiUsage' in data) || (data.aiUsage is map && ('tokensUsed' in data.aiUsage) && (data.aiUsage.tokensUsed is number) && ('limit' in data.aiUsage) && (data.aiUsage.limit is number) && ('resetDate' in data.aiUsage) && (data.aiUsage.resetDate is string))) &&
             (!('role' in data) || data.role in ['patient', 'doctor', 'admin']);
    }

    function isValidReading(data) {
      return data.systolic is number && data.systolic >= 40 && data.systolic <= 300 &&
             data.diastolic is number && data.diastolic >= 30 && data.diastolic <= 200 &&
             (!('heartRate' in data) || data.heartRate == null || (data.heartRate is number && data.heartRate >= 30 && data.heartRate <= 250)) &&
             data.order is number && data.order >= 1 && data.order <= 3 &&
             data.slot in ['morning', 'evening'] &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.recordedAt is timestamp &&
             data.userUid == request.auth.uid &&
             (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 1000)) &&
             (!('category' in data) || data.category == null || (data.category is string && data.category.size() <= 100)) &&
             (!('periodId' in data) || data.periodId == null || data.periodId is number) &&
             (!('weekId' in data) || data.weekId == null || (data.weekId is string && data.weekId.size() <= 20)) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidAiReport(data) {
      return data.userUid == request.auth.uid &&
             data.createdAt is string &&
             data.cycleId is string &&
             data.title is string && data.title.size() <= 200 &&
             data.executiveSummary is string && data.executiveSummary.size() <= 6000 &&
             data.dataQuality is number && data.dataQuality >= 0 && data.dataQuality <= 100 &&
             (!('recommendation' in data) || (data.recommendation is string && data.recommendation.size() <= 2000)) &&
             (!('impact' in data) || (data.impact is string && data.impact.size() <= 200)) &&
             (!('nextReview' in data) || data.nextReview is string) &&
             (!('healthFocus' in data) || data.healthFocus is string) &&
             (!('isComparative' in data) || data.isComparative is bool) &&
             (data.findings is list && data.findings.size() <= 30) &&
             (data.projectionData is list && data.projectionData.size() <= 60);
    }

    function isValidAiAnalysis(data) {
      return data.userUid == request.auth.uid &&
             data.analysis is string &&
             data.type in ['bp', 'pulse'] &&
             data.period is string &&
             data.createdAt is string;
    }

    function isValidAuthorization(data) {
      // Allow admin or the owner to create auth documents
      return (data.patientId == request.auth.uid || isAdmin()) &&
             data.doctorId is string && data.doctorId.size() <= 128 &&
             data.patientId is string && data.patientId.size() <= 128 &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (!('status' in data) || data.status in ['active', 'revoked']) &&
             (!('doctorName' in data) || data.doctorName is string) &&
             (!('patientName' in data) || data.patientName is string) &&
             (!('patientEmail' in data) || data.patientEmail is string);
    }

    // ===============================================================
    // Root Collection: Authorizations
    // ===============================================================
    match /authorizations/{authId} {
      allow read: if isSignedIn() && (request.auth.uid in authId.split('_') || isAdmin());
      allow create: if isSignedIn() && 
                    authId == incoming().doctorId + '_' + incoming().patientId &&
                    incoming().keys().hasOnly(['patientId', 'doctorId', 'createdAt', 'status', 'doctorName', 'patientName', 'patientEmail']) &&
                    incoming().keys().hasAll(['patientId', 'doctorId', 'createdAt']) &&
                    isValidAuthorization(incoming());
      allow update: if isSignedIn() && 
                    (isOwner(existing().patientId) || isAdmin()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                    isValidAuthorization(incoming());
      allow delete: if isSignedIn() && (isOwner(existing().patientId) || isAdmin());
    }

    // ===============================================================
    // Root Collection: Users
    // ===============================================================
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin() || isAuthorizedDoctor(userId) || resource.data.get('role', 'patient') == 'doctor');
      
      allow create: if isOwner(userId) && isVerified() && isValidId(userId) &&
                    // Prevent shadow writes with strict keys matching
                    incoming().keys().hasOnly(['uid', 'email', 'createdAt', 'displayName', 'photoURL', 'sex', 'age', 'height', 'weight', 'isSmoker', 'hasDiabetes', 'isHypertensiveMedicated', 'activityLevel', 'alcoholConsumption', 'saltIntake', 'stressLevel', 'sleepQuality', 'familyHistory', 'caffeineIntake', 'hasHighCholesterol', 'hasKidneyDisease', 'updatedAt', 'aiUsage', 'role']) &&
                    incoming().keys().hasAll(['uid', 'email', 'createdAt']) && 
                    isValidUser(incoming());
      
      allow update: if (isOwner(userId) || isAdmin()) && isVerified() && isValidId(userId) &&
                    incoming().get('uid', null) == existing().get('uid', null) &&
                    incoming().get('createdAt', null) == existing().get('createdAt', null) &&
                    (isAdmin() || !incoming().diff(existing()).affectedKeys().hasAny(['role'])) && // Admin can change roles
                    // Enforce allowed update fields to prevent shadow writes
                    incoming().diff(existing()).affectedKeys().hasOnly(['email', 'displayName', 'photoURL', 'sex', 'age', 'height', 'weight', 'isSmoker', 'hasDiabetes', 'isHypertensiveMedicated', 'activityLevel', 'alcoholConsumption', 'saltIntake', 'stressLevel', 'sleepQuality', 'familyHistory', 'caffeineIntake', 'hasHighCholesterol', 'hasKidneyDisease', 'updatedAt', 'aiUsage', 'role']) &&
                    isValidUser(incoming());
      
      allow delete: if isAdmin(); // Extreme action
    }

    // ===============================================================
    // Sub-collection: Readings
    // ===============================================================
    match /users/{userId}/readings/{readingId} {
      // Secure List Queries: Evaluation of resource.data is mandatory for allow list
      allow list: if isSignedIn() && (isOwner(userId) || isAdmin() || isAuthorizedDoctor(userId));
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin() || isAuthorizedDoctor(userId));
      
      allow create: if isOwner(userId) && isVerified() && 
                    isValidId(readingId) &&
                    // Enforce exact shape
                    incoming().keys().hasOnly(['systolic', 'diastolic', 'order', 'slot', 'recordedAt', 'date', 'userUid', 'heartRate', 'notes', 'category', 'periodId', 'weekId', 'updatedAt']) &&
                    incoming().keys().hasAll(['systolic', 'diastolic', 'order', 'slot', 'recordedAt', 'date', 'userUid']) &&
                    isValidReading(incoming());
      
      allow update: if isOwner(userId) && isVerified() &&
                    // Immortal Fields (Immutability check)
                    incoming().recordedAt == existing().recordedAt &&
                    incoming().order == existing().order &&
                    incoming().slot == existing().slot &&
                    incoming().date == existing().date &&
                    incoming().userUid == existing().userUid &&
                    // Action-Based affected keys check
                    incoming().diff(existing()).affectedKeys().hasOnly(['systolic', 'diastolic', 'heartRate', 'notes', 'category', 'updatedAt']) &&
                    isValidReading(incoming());
      
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ===============================================================
    // Sub-collection: AI Reports & Analysis
    // ===============================================================
    match /users/{userId}/ai_reports/{reportId} {
      allow list: if isSignedIn() && (isOwner(userId) || isAdmin() || isAuthorizedDoctor(userId));
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin() || isAuthorizedDoctor(userId));
      
      allow create: if isOwner(userId) && isVerified() && 
                    isValidId(reportId) &&
                    incoming().keys().hasOnly(['userUid', 'createdAt', 'cycleId', 'title', 'executiveSummary', 'dataQuality', 'findings', 'projectionData', 'recommendation', 'impact', 'nextReview', 'healthFocus', 'isComparative']) &&
                    incoming().keys().hasAll(['userUid', 'createdAt', 'cycleId', 'title', 'executiveSummary', 'dataQuality', 'findings', 'projectionData']) &&
                    isValidAiReport(incoming());
      
      allow update: if false; // Reports are typically static once generated
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/ai_analysis/{analysisId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin() || isAuthorizedDoctor(userId));
      allow create, update: if isOwner(userId) && isVerified() && 
                            isValidId(analysisId) &&
                            // Create keys check
                            (request.method == 'create' ? incoming().keys().hasOnly(['userUid', 'analysis', 'type', 'period', 'createdAt']) && incoming().keys().hasAll(['userUid', 'analysis', 'type', 'period', 'createdAt']) : true) &&
                            (request.method == 'update' ? incoming().diff(existing()).affectedKeys().hasOnly(['analysis']) : true) &&
                            isValidAiAnalysis(incoming());
      allow delete: if isOwner(userId) || isAdmin();
    }
  }
}
