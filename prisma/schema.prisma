generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Reading {
  id         String   @id @default(uuid())
  systolic   Int
  diastolic  Int
  heartRate  Int?
  order      Int      // 1, 2, 3
  recordedAt DateTime @default(now())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Session {
  id           String    @id @default(uuid())
  slot         String    // "morning", "evening"
  avgSystolic  Float?
  avgDiastolic Float?
  completedAt  DateTime?
  dayId        String
  day          Day       @relation(fields: [dayId], references: [id], onDelete: Cascade)
  readings     Reading[]
}

model Day {
  id           String    @id @default(uuid())
  date         DateTime  @unique
  avgSystolic  Float?
  avgDiastolic Float?
  periodId     String?
  period       Period?   @relation(fields: [periodId], references: [id])
  sessions     Session[]
}

model Period {
  id                  String   @id @default(uuid())
  startDate           DateTime
  endDate             DateTime
  morningAvgSystolic  Float?
  morningAvgDiastolic Float?
  eveningAvgSystolic  Float?
  eveningAvgDiastolic Float?
  finalAvgSystolic    Float?
  finalAvgDiastolic   Float?
  days                Day[]
}
